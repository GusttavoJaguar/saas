
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Saas Landing Page</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>



  <h1 class="text-center mt-5">Bem-vindo ao nosso SaaS de criação de lojas online!</h1>
  <p class="text-center mb-5">Acesse sua loja personalizada ou explore as lojas de outros usuários.</p>


  <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">

    <div class="w-100" style="max-width: 400px;">

      <h2 class="text-center mb-4">Link de lojas</h2>

      <% @stores.each do |store| %>

        <div class="card mb-3 shadow-sm border-0">

          <div class="card-body d-flex align-items-center justify-content-between">

            <!-- LOGO + NOME -->
            <div class="d-flex align-items-center gap-3">

              <% if store.logo.attached? %>
                <%= image_tag store.logo,
                  style: "width: 50px; height: 50px; object-fit: cover; border-radius: 10px;" %>
              <% end %>

              <strong>@<%= store.name %></strong>

            </div>

            <!-- BOTÃO -->
            <% if user_signed_in? %>
            <%= link_to "Abrir",
                  store_path(store),
                  class: "btn btn-sm btn-primary" %>
            <% else %>
            <%= link_to "Abrir",
                  public_store_path(store),
                  class: "btn btn-sm btn-secondary" %>
            <% end %>

          </div>

        </div>

      <% end %>

    </div>

  </div>

<div class="text-center mt-3 p-3 border rounded m-3">     

  <% if user_signed_in? %>
    <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "m-2 btn btn-danger" %>
  <% else %>
    <%= link_to "login", new_user_session_path, class: "btn btn-success m-2" %>
  <% end %>
</div>

